diff --git a/lvgl/src/drivers/display/drm/lv_linux_drm.c b/lvgl/src/drivers/display/drm/lv_linux_drm.c
index 5a9e93756..6d4d8796a 100644
--- a/lvgl/src/drivers/display/drm/lv_linux_drm.c
+++ b/lvgl/src/drivers/display/drm/lv_linux_drm.c
@@ -163,8 +163,14 @@ void lv_linux_drm_set_file(lv_display_t * disp, const char * file, int64_t conne
      * to lv_display_create then the buffers aren't big enough for LV_DISPLAY_RENDER_MODE_DIRECT.
      */
     lv_display_set_resolution(disp, hor_res, ver_res);
-    lv_display_set_buffers(disp, drm_dev->drm_bufs[1].map, drm_dev->drm_bufs[0].map, buf_size,
-                           LV_DISPLAY_RENDER_MODE_DIRECT);
+
+    // Allocate a 32-bit "Scratchpad" for LVGL (1024 * 600 * 4 bytes)
+    uint32_t * draw_buf = lv_malloc(hor_res * ver_res * sizeof(uint32_t));
+
+    // Give LVGL the 32-bit scratchpad, but NOT the DRM maps
+    lv_display_set_buffers(disp, draw_buf, NULL, hor_res * ver_res * sizeof(uint32_t), 
+                       LV_DISPLAY_RENDER_MODE_PARTIAL);
+    
 
     if(width) {
         lv_display_set_dpi(disp, DIV_ROUND_UP(hor_res * 25400, width * 1000));
@@ -825,29 +831,36 @@ static void drm_flush(lv_display_t * disp, const lv_area_t * area, uint8_t * px_
 {
     if(!lv_display_flush_is_last(disp)) return;
 
-    LV_UNUSED(area);
     drm_dev_t * drm_dev = lv_display_get_driver_data(disp);
-
-    for(int idx = 0; idx < 2; idx++) {
-        if(drm_dev->drm_bufs[idx].map == px_map) {
-            /* Rotate the buffer 180° into the other (non-displayed) DRM buffer */
-            int dst_idx = idx ^ 1;
-            lv_draw_sw_rotate(px_map, drm_dev->drm_bufs[dst_idx].map,
-                              drm_dev->width, drm_dev->height,
-                              drm_dev->drm_bufs[idx].pitch,
-                              drm_dev->drm_bufs[dst_idx].pitch,
-                              LV_DISPLAY_ROTATION_180,
-                              lv_display_get_color_format(disp));
-
-            /*Request buffer swap*/
-            if(drm_dmabuf_set_plane(drm_dev, &drm_dev->drm_bufs[dst_idx])) {
-                LV_LOG_ERROR("Flush fail");
-                return;
-            }
-            else
-                LV_LOG_TRACE("Flush done");
+    
+    /* We need to pick a destination DRM buffer. 
+       Let's just toggle between our two dumb buffers. */
+    static int side = 0;
+    side ^= 1; 
+    uint8_t * dst24 = drm_dev->drm_bufs[side].map;
+    uint32_t * src32 = (uint32_t *)px_map;
+
+    /* MANUALLY CONVERT 32-BIT TO 24-BIT */
+    for (int y = 0; y < drm_dev->height; y++) {
+        for (int x = 0; x < drm_dev->width; x++) {
+            uint32_t pixel = src32[y * drm_dev->width + x];
+            
+            // Use hardware pitch for the destination to avoid the 'slant'
+            int dst_idx = (y * drm_dev->pitch) + (x * 3);
+            
+            dst24[dst_idx + 0] = (pixel >> 16) & 0xFF; // R
+            dst24[dst_idx + 1] = (pixel >> 8) & 0xFF;  // G
+            dst24[dst_idx + 2] = (pixel & 0xFF);       // B
         }
     }
+
+    /* Request buffer swap */
+    if(drm_dmabuf_set_plane(drm_dev, &drm_dev->drm_bufs[side])) {
+        LV_LOG_ERROR("Flush fail");
+    }
+
+    /* IMPORTANT: You MUST call this in v9+ or the UI will freeze */
+    lv_display_flush_ready(disp);
 }
 
