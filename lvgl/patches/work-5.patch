+    if(lv_display_flush_is_last(disp)) {
+        
+        // 1024 * 4 = 4096. This is what LVGL actually filled.
+        uint32_t lvgl_packed_stride = drm_dev->width * 4; 
+
+        lv_draw_sw_rotate(
+            px_map,                                 // Source: bufs[1]
