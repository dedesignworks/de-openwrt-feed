diff --git a/lvgl/src/drivers/display/drm/lv_linux_drm.c b/lvgl/src/drivers/display/drm/lv_linux_drm.c
index 5a9e93756..030c1b956 100644
--- a/lvgl/src/drivers/display/drm/lv_linux_drm.c
+++ b/lvgl/src/drivers/display/drm/lv_linux_drm.c
@@ -823,31 +823,35 @@ static void drm_flush_wait(lv_display_t * disp)
 
 static void drm_flush(lv_display_t * disp, const lv_area_t * area, uint8_t * px_map)
 {
-    if(!lv_display_flush_is_last(disp)) return;
-
-    LV_UNUSED(area);
     drm_dev_t * drm_dev = lv_display_get_driver_data(disp);
-
-    for(int idx = 0; idx < 2; idx++) {
-        if(drm_dev->drm_bufs[idx].map == px_map) {
-            /* Rotate the buffer 180° into the other (non-displayed) DRM buffer */
-            int dst_idx = idx ^ 1;
-            lv_draw_sw_rotate(px_map, drm_dev->drm_bufs[dst_idx].map,
-                              drm_dev->width, drm_dev->height,
-                              drm_dev->drm_bufs[idx].pitch,
-                              drm_dev->drm_bufs[dst_idx].pitch,
-                              LV_DISPLAY_ROTATION_180,
-                              lv_display_get_color_format(disp));
-
-            /*Request buffer swap*/
-            if(drm_dmabuf_set_plane(drm_dev, &drm_dev->drm_bufs[dst_idx])) {
-                LV_LOG_ERROR("Flush fail");
-                return;
-            }
-            else
-                LV_LOG_TRACE("Flush done");
+    
+    // 1. Identify which DRM buffer is NOT currently on screen
+    // We'll use a static toggle to keep track of our internal double-buffering
+    static int drm_buffer_idx = 0;
+    int target_idx = drm_buffer_idx;
+
+    // 2. Rotate the entire drawing buffer into the DRM dumb buffer
+    // Since we are in PARTIAL mode, we do this on the 'last' flush call for the frame
+    if(lv_display_flush_is_last(disp)) {
+        lv_draw_sw_rotate(px_map, 
+                          drm_dev->drm_bufs[target_idx].map,
+                          drm_dev->width, 
+                          drm_dev->height,
+                          drm_dev->width * (LV_COLOR_DEPTH/8), // pitch src
+                          drm_dev->drm_bufs[target_idx].pitch, // pitch dst
+                          LV_DISPLAY_ROTATION_180,
+                          lv_display_get_color_format(disp));
+
+        // 3. Tell DRM to show the buffer we just filled
+        if(drm_dmabuf_set_plane(drm_dev, &drm_dev->drm_bufs[target_idx])) {
+            LV_LOG_ERROR("DRM Atomic Commit Failed");
         }
+
+        // 4. Swap index for the next frame
+        drm_buffer_idx ^= 1;
     }
+
+    lv_display_flush_ready(disp);
 }
 
 static uint32_t tick_get_cb(void)
